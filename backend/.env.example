# =============================================================================
# OIT Helpdesk Dashboard — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Jira connection
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_BASE_URL=https://your-instance.atlassian.net
JIRA_PROJECT=OIT

# Data directory (inside Docker this is /app/data, mounted as a volume)
DATA_DIR=/app/data

# AI provider keys (at least one required for triage features)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=

# Auto-triage model (runs on new tickets during cache refresh)
AUTO_TRIAGE_MODEL=gpt-4o-mini

# Production CORS origin (optional — your dashboard URL)
# CORS_ORIGIN=https://dashboard.yourcompany.com
