# =============================================================================
# OIT Helpdesk Dashboard — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Jira connection
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_BASE_URL=https://your-instance.atlassian.net
JIRA_PROJECT=OIT
JIRA_FOLLOWUP_LAST_PUBLIC_AGENT_TOUCH_FIELD_ID=
JIRA_FOLLOWUP_PUBLIC_AGENT_TOUCH_COUNT_FIELD_ID=
JIRA_FOLLOWUP_STATUS_FIELD_ID=
JIRA_FOLLOWUP_BREACHED_AT_FIELD_ID=
JIRA_FOLLOWUP_AGENT_GROUPS=
AZURE_FINOPS_RECOMMENDATION_JIRA_PROJECT=OIT
AZURE_FINOPS_RECOMMENDATION_JIRA_ISSUE_TYPE=Task
AZURE_FINOPS_RECOMMENDATION_TEAMS_WEBHOOK_URL=
AZURE_FINOPS_RECOMMENDATION_TEAMS_CHANNEL_LABEL=FinOps

# Data directory (inside Docker this is /app/data, mounted as a volume)
DATA_DIR=/app/data

# Local AI provider (Ollama is the default runtime path)
OLLAMA_ENABLED=1
# When the app runs in Docker, docker-compose overrides this to host.docker.internal.
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Quality/default model for richer responses
OLLAMA_MODEL=qwen2.5:7b
# Faster model for small structured tasks like triage and QA
OLLAMA_FAST_MODEL=qwen2.5:3b
OLLAMA_KEEP_ALIVE=15m

# Optional cloud-provider keys. Leave blank when running Ollama-only.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Fast-path structured AI models
AUTO_TRIAGE_MODEL=qwen2.5:3b
TECHNICIAN_SCORE_MODEL=qwen2.5:3b
AZURE_ALERT_RULE_MODEL=qwen2.5:3b
TECHNICIAN_SCORE_POLL_INTERVAL_MINUTES=60

# Production CORS origin (optional — your dashboard URL)
# CORS_ORIGIN=https://dashboard.yourcompany.com

# Azure Cost export ingestion lane
AZURE_COST_EXPORTS_ENABLED=0
AZURE_COST_EXPORT_ROOT=/app/data/azure_cost_exports
AZURE_COST_EXPORT_DATASETS=FOCUS
AZURE_COST_EXPORT_MANIFEST_DB_PATH=/app/data/azure_export_deliveries.db
AZURE_FINOPS_DUCKDB_PATH=/app/data/azure_finops.duckdb
# Optional JSON pricing map for AI cost tracking, for example:
# AZURE_FINOPS_AI_PRICING_JSON={"providers":{"ollama":{"input_per_1k_tokens":0,"output_per_1k_tokens":0,"currency":"USD"}},"models":{"gpt-4.1":{"input_per_1k_tokens":0.01,"output_per_1k_tokens":0.03,"currency":"USD"}}}
AZURE_FINOPS_AI_PRICING_JSON=
# Optional JSON team attribution map for AI usage rollups, for example:
# AZURE_FINOPS_AI_TEAM_MAPPINGS_JSON={"feature_surfaces":{"ticket_auto_triage":"Service Desk","technician_qa":"Service Desk","azure_cost_copilot":"FinOps"},"app_surfaces":{"tickets":"Service Desk","knowledge_base":"Service Desk","azure_portal":"FinOps","azure_alerts":"FinOps"},"actor_ids":{"azure-alerts":"FinOps"}}
AZURE_FINOPS_AI_TEAM_MAPPINGS_JSON=
# Optional JSON allowlist for safe remediation hooks, for example:
# AZURE_FINOPS_SAFE_SCRIPT_HOOKS_JSON={"vm_echo":{"label":"VM Echo","description":"Dry-run starter hook for compute recommendations.","command":["python3","/app/backend/scripts/azure_finops_safe_hook_echo.py"],"allowed_categories":["compute"],"default_dry_run":true,"allow_apply":false}}
AZURE_FINOPS_SAFE_SCRIPT_HOOKS_JSON=
AZURE_COST_EXPORT_STAGING_DIR=/app/data/azure_cost_exports/_staged
AZURE_COST_EXPORT_QUARANTINE_DIR=/app/data/azure_cost_exports/_quarantine
AZURE_COST_EXPORT_EXPECTED_CADENCE_HOURS=24
AZURE_COST_EXPORT_POLL_INTERVAL_MINUTES=15
AZURE_VIRTUAL_DESKTOP_REMOVAL_THRESHOLD_DAYS=14
AZURE_AVD_SESSION_HISTORY_LOOKBACK_DAYS=90
AZURE_REPORTING_POWER_BI_URL=
AZURE_REPORTING_POWER_BI_LABEL=Shared Cost Dashboard
AZURE_REPORTING_COST_ANALYSIS_URL=
AZURE_REPORTING_COST_ANALYSIS_LABEL=Azure Cost Analysis

# Microsoft Entra ID (Azure AD) authentication
# For email alerts, the app registration also needs Mail.Send application permission
ENTRA_TENANT_ID=your-tenant-id
ENTRA_CLIENT_ID=your-client-id
ENTRA_CLIENT_SECRET=your-client-secret
ALLOWED_USERS=                    # comma-separated emails, empty = allow all
APP_SECRET_KEY=replace-with-a-long-random-secret
PRIMARY_AUTH_PROVIDER=atlassian
OASISDEV_AUTH_PROVIDER=atlassian
AZURE_AUTH_PROVIDER=entra
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
ATLASSIAN_ALLOWED_SITE_URL=https://your-instance.atlassian.net
ATLASSIAN_ACCESS_GROUPS=jira-servicemanagement-users-keyjira,MoveDocs Service Desk Agents
ATLASSIAN_ADMIN_GROUPS=MoveDocs Service Desk Agents
# Generate with: python - <<'PY'\n# from cryptography.fernet import Fernet\n# print(Fernet.generate_key().decode())\n# PY
ATLASSIAN_TOKEN_ENCRYPTION_KEY=

# Optional private KB seed archive path mounted into the container.
# Keep the real archive outside git, for example:
#   ./private/OIT_KB_Articles.zip -> /app/private/OIT_KB_Articles.zip
KB_ARTICLE_ARCHIVE=/app/private/OIT_KB_Articles.zip

# Cloudflare API Token (for Let's Encrypt DNS-01 via Caddy)
# Create at: Cloudflare Dashboard > My Profile > API Tokens > Create Token
# Permission: Zone : DNS : Edit, scoped to movedocs.com
# Also set in root .env (Docker Compose reads it for the Caddy container)
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
